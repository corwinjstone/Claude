{
  "division": "triathlon",
  "display_name": "Triathlon",
  "owning_team": "Triathlon Registration",

  "subdistances": {
    "sprint":   { "swim_m":  750, "bike_km":  20, "run_km":  5,    "cutoff_hours": 2.0 },
    "olympic":  { "swim_m": 1500, "bike_km":  40, "run_km": 10,    "cutoff_hours": 4.0 },
    "half":     { "swim_m": 1900, "bike_km":  90, "run_km": 21.1,  "cutoff_hours": 8.5 },
    "full":     { "swim_m": 3800, "bike_km": 180, "run_km": 42.2,  "cutoff_hours": 17.0 }
  },

  "eligibility": {
    "age_minimum_years_sprint": 13,
    "age_minimum_years_olympic": 15,
    "age_minimum_years_half": 18,
    "age_minimum_years_full": 18,
    "age_groups": [
      "13-15", "16-19", "20-24", "25-29", "30-34", "35-39", "40-44",
      "45-49", "50-54", "55-59", "60-64", "65-69", "70-74", "75-79", "80+"
    ],
    "para_divisions": [
      "PTWC1", "PTWC2", "PTS2", "PTS3", "PTS4", "PTS5", "PTVI1", "PTVI2", "PTVI3"
    ]
  },

  "registration_required_fields": [
    "legal_name",
    "date_of_birth",
    "gender_division",
    "email",
    "phone",
    "emergency_contact_name",
    "emergency_contact_phone",
    "usat_membership_number_or_one_day_license",
    "bike_make_model",
    "wetsuit_declaration",
    "shirt_size",
    "medical_attestation_v3",
    "waiver_v7",
    "predicted_swim_pace_per_100m"
  ],

  "pricing": {
    "default_tiers_sprint": [
      { "name": "early_bird", "weeks_before": 20, "default_price_usd": 85 },
      { "name": "regular",    "weeks_before": 8,  "default_price_usd": 110 },
      { "name": "late",       "weeks_before": 2,  "default_price_usd": 135 }
    ],
    "default_tiers_full": [
      { "name": "early_bird", "weeks_before": 40, "default_price_usd": 450 },
      { "name": "regular",    "weeks_before": 20, "default_price_usd": 575 },
      { "name": "late",       "weeks_before": 6,  "default_price_usd": 700 }
    ]
  },

  "refund_policy": {
    "full_refund_until_days_before": 90,
    "partial_refund_percent": 40,
    "partial_refund_until_days_before": 30,
    "no_refund_inside_days_before": 30,
    "medical_exception_with_documentation": true
  },

  "transfer_policy": {
    "athlete_to_athlete_allowed": true,
    "deadline_days_before": 30,
    "transfer_fee_usd": 50
  },

  "deferral_policy": {
    "allowed": true,
    "max_years": 1,
    "fee_usd": 75,
    "deadline_days_before": 45
  },

  "qualifying": {
    "required": false,
    "world_championship_qualifier_supported": true
  },

  "wetsuit_rules": {
    "legal_below_water_temp_celsius": 21.9,
    "mandatory_below_water_temp_celsius": 15.5,
    "swim_canceled_below_temp_celsius": 13.0
  },

  "transition_rules": {
    "rack_assignment_method": "by_age_group_then_bib",
    "helmet_required_buckled_before_bike_off_rack": true,
    "no_drafting_zone_meters_olympic": 12,
    "no_drafting_zone_meters_half_full": 12
  },

  "mandatory_gear": [
    "swim_cap_event_issued",
    "approved_helmet",
    "race_belt_or_safety_pinned_bib",
    "closed_toe_run_shoes"
  ],

  "medical": {
    "attestation_required": true,
    "physician_signoff_required_for_full": true,
    "course_aid_spacing_max_km_run_leg": 2.5,
    "swim_safety_kayaks_per_100_athletes": 4,
    "medical_tent_at_t1_t2_finish": true
  },

  "weather_protocols": {
    "swim_canceled_lightning_within_km": 16,
    "wbgt_run_leg_modification_celsius": 28
  }
}
